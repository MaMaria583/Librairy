generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductType {
  LIVRE
  FOURNITURE
}

enum PaymentMethod {
  ESPECES
  CARTE
  CHEQUE
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  type          ProductType

  // Commun
  name          String
  buyPrice      Float
  sellPrice     Float
  stock         Int         @default(0)
  alertThreshold Int        @default(5)
  barcode       String?     @unique
  supplierId    String?
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])

  // Spécifique LIVRE
  author        String?
  publisher     String?
  isbn          String?     @unique
  genre         String?
  location      String?

  // Spécifique FOURNITURE
  brand         String?
  category      String?
  sku           String?

  imageUrl      String?
  description   String?     @db.Text
  isNew         Boolean     @default(false)
  isCollection  Boolean     @default(false)

  saleItems     SaleItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Sale {
  id            String        @id @default(cuid())
  total         Float
  subtotal      Float
  taxAmount     Float         @default(0)
  discount      Float         @default(0)
  amountPaid    Float
  change        Float         @default(0)
  paymentMethod PaymentMethod @default(ESPECES)
  notes         String?
  items         SaleItem[]
  createdAt     DateTime      @default(now())
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Float
  discount   Float    @default(0)
  subtotal   Float
}

model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  password      String
  createdAt     DateTime          @default(now())
  subscriptions UserSubscription[]
}

model UserSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  genre     String
  createdAt DateTime @default(now())

  @@unique([userId, genre])
}

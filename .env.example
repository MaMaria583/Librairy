# URL de connexion via le pooler (utilisé par l'application en production)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# URL directe (utilisée par Prisma pour les migrations)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth - générer avec: npx auth secret
AUTH_SECRET="votre_secret_aleatoire_ici"

# Google OAuth - obtenir sur https://console.cloud.google.com
GOOGLE_CLIENT_ID="votre_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="votre_google_client_secret"

# Groq IA - obtenir sur https://console.groq.com/keys
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Notifications commandes payées ──────────────────────────────────────────

# Option 1 : Email via Resend (gratuit 3000 emails/mois — resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NOTIFICATION_EMAIL="votre_email@exemple.com"
# Expéditeur vérifié sur resend.com (laisser vide pour utiliser onboarding@resend.dev en test)
RESEND_FROM_EMAIL="noreply@votredomaine.com"

# Option 2 : Webhook (Make.com / Zapier / n8n → WhatsApp / Email)
# Créez un scénario sur Make.com, copiez l'URL du webhook ici
NOTIFICATION_WEBHOOK_URL="https://hook.eu2.make.com/xxxxxxxxxxxxxxxxxxxx"

# ── WhatsApp Business Cloud API (Meta) ──────────────────────────────────────
# Guide complet : voir README ou docs/whatsapp-setup.md

# Chaîne aléatoire de votre choix — à copier EXACTEMENT dans Meta Developer Console
WHATSAPP_VERIFY_TOKEN="darelhikma_webhook_2024"

# Token d'accès permanent — Meta Developer Console → WhatsApp → Configuration
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ID du numéro de téléphone — Meta Developer Console → WhatsApp → Numéros de téléphone
WHATSAPP_PHONE_NUMBER_ID="1234567890123456"

# App Secret — Meta Developer Console → Paramètres de base → App Secret
# Utilisé pour vérifier l'authenticité des webhooks entrants (sécurité HMAC-SHA256)
WHATSAPP_APP_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
